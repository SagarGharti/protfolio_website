{
  "name": "tailwind-framer-project",
  "version": "1.0.0",
  "description": "A modern web project with Tailwind CSS and Framer Motion",
  "type": "module",
  "scripts": {
    "dev": "npx tailwindcss -i ./src/index.css -o ./dist/output.css --watch",
    "build": "npx tailwindcss -i ./src/index.css -o ./dist/output.css --minify"
  },
  "dependencies": {
    "remix": "^2.17.4"
  },
  "devDependencies": {
    "autoprefixer": "^10.4.27",
    "postcss": "^8.5.8",
    "tailwindcss": "^3.4.19"
  }
}
